# Define Entity List for Observation
ENTITY_LIST = [
    "EmptyEntity",
    "Wall",
    "Gem",
    "Agent",
    {% for entity in entities %}
    "{{ entity.name }}",
    {% endfor %}
]

class {{ project_name }}Env(Environment[{{ project_name }}World]):
    def setup_agents(self):
        # Configure agents based on specs
        self.agents = []
        for _ in range({{ num_agents }}):
            # Define Observation Spec
            observation_spec = OneHotObservationSpec(
                entity_list=ENTITY_LIST,
                full_view=False,
                vision_radius={{ vision }}
            )
            
            # Action Spec
            action_spec = ActionSpec({{ actions }})
            
            # Model Instantiation
            {% if model == "RandomModel" %}
            model = RandomModel(input_size=observation_spec.input_size, action_space=action_spec.n_actions, memory_size={{ model_params.get('memory_size', 1000) }})
            {% elif model == "PyTorchIQN" %}
            model = PyTorchIQN(
                input_size=observation_spec.input_size, 
                action_space=action_spec.n_actions,
                layer_size={{ model_params.get('layer_size', 256) }},
                epsilon={{ model_params.get('epsilon', 1.0) }},
                device="cpu",
                seed=torch.random.seed(),
                n_frames={{ model_params.get('n_frames', 1) }},
                n_quantiles={{ model_params.get('n_quantiles', 8) }}
            )
            {% elif model == "HumanPlayer" %}
            model = HumanPlayer(input_size=observation_spec.input_size, action_space=action_spec.n_actions, memory_size={{ model_params.get('memory_size', 1000) }})
            {% endif %}
            
            agent = {{ project_name }}Agent(observation_spec, action_spec, model)
            self.agents.append(agent)

