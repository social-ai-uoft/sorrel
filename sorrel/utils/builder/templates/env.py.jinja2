    def populate_environment(self):
        # Add generated layout
        layout = {{ layout_data }}
        
        # Track manual agent locations from layout
        manual_agent_locations = []

        for (r, c), entity_name in layout:
            if entity_name == "Wall":
                self.world.add((r, c, 0), Wall())
            elif entity_name == "Agent":
                manual_agent_locations.append((r, c))
            # Add other entities dynamically based on name
            # This part requires a mapping or dynamic instantiation
            {% for entity in entities %}
            elif entity_name == "{{ entity.name }}":
                {% if entity.name == "Gem" %}
                self.world.add((r, c, 0), Gem(value=1))
                {% else %}
                self.world.add((r, c, 0), {{ entity.name }}())
                {% endif %}
            {% endfor %}

        # Place agents
        # 1. Place agents at manual locations found in layout
        # 2. Place remaining agents at random empty locations
        
        # Get all empty locations for random placement
        empty_locations = []
        for r in range(self.world.height):
            for c in range(self.world.width):
                # Check if location is empty and not a wall/obstacle
                # (Simple check: if we didn't put anything there on layer 0)
                # Note: This assumes layer 0 is the main object layer
                if isinstance(self.world.observe((r, c, 0)), EmptyEntity) and (r, c) not in manual_agent_locations:
                     empty_locations.append((r, c))

        if len(empty_locations) < (len(self.agents) - len(manual_agent_locations)):
            print("Warning: Not enough empty spots for random agent placement!")

        # Shuffle empty locations
        np.random.shuffle(empty_locations)
        
        for i, agent in enumerate(self.agents):
            if i < len(manual_agent_locations):
                loc = manual_agent_locations[i]
                self.world.add((*loc, 1), agent)
            elif empty_locations:
                loc = empty_locations.pop()
                self.world.add((*loc, 1), agent)
            else:
                # Fallback if no spots left (should generally be handled by grid size)
                pass

