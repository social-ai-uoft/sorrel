from typing import List
import numpy as np
import torch
from pathlib import Path
from datetime import datetime

from sorrel.environment import Environment
from sorrel.action.action_spec import ActionSpec
{% if model == "RandomModel" %}
from sorrel.models import RandomModel
{% elif model == "PyTorchIQN" %}
from sorrel.models import PyTorchIQN
{% elif model == "HumanPlayer" %}
from sorrel.models import HumanPlayer
{% endif %}
from sorrel.entities.basic_entities import EmptyEntity, Wall, Gem
from sorrel.observation.observation_spec import OneHotObservationSpec
from sorrel.utils.logging import {{ logger_type }}

from sorrel.examples.{{ project_name_lower }}.world import {{ project_name }}World
from sorrel.examples.{{ project_name_lower }}.agents import {{ project_name }}Agent
from sorrel.examples.{{ project_name_lower }}.entities import *

# Define Entity List for Observation
ENTITY_LIST = [
    "EmptyEntity",
    "Wall",
    "{{ project_name }}Agent",
    {% for entity in entities %}
    "{{ entity.name }}",
    {% endfor %}
]


class {{ project_name }}Env(Environment[{{ project_name }}World]):
    def setup_agents(self):
        self.agents = []
        for _ in range({{ num_agents }}):
            observation_spec = OneHotObservationSpec(
                entity_list=ENTITY_LIST,
                full_view=False,
                vision_radius={{ vision }}
            )

            action_spec = ActionSpec({{ actions }})

            {% if model == "RandomModel" %}
            model = RandomModel(
                input_size=observation_spec.input_size,
                action_space=action_spec.n_actions,
                memory_size={{ model_params.get("memory_size", 1000) }},
            )
            {% elif model == "PyTorchIQN" %}
            model = PyTorchIQN(
                input_size=observation_spec.input_size,
                action_space=action_spec.n_actions,
                layer_size={{ model_params.get("layer_size", 256) }},
                epsilon={{ model_params.get("epsilon", 1.0) }},
                device="cpu",
                seed=torch.random.seed(),
                n_frames={{ model_params.get("n_frames", 1) }},
                n_quantiles={{ model_params.get("n_quantiles", 8) }},
            )
            {% elif model == "HumanPlayer" %}
            model = HumanPlayer(
                input_size=observation_spec.input_size,
                action_space=action_spec.n_actions,
                memory_size={{ model_params.get("memory_size", 1000) }},
            )
            {% endif %}

            agent = {{ project_name }}Agent(observation_spec, action_spec, model)
            self.agents.append(agent)

    def _handle_interaction(self, agent: "{{ project_name }}Agent", action_name: str):
        """Apply interaction rules based on the action performed and the faced entity."""
        # _facing_location is set by act() each turn before this is called
        if agent._facing_location is None:
            return

        target_entity = self.world.observe(agent._facing_location)
        if target_entity is None:
            return

        {% if rules %}
        # --- Generated Interaction Rules ---
        {%- for rule in rules %}
        # Rule: if agent does "{{ rule.action }}" on {{ rule.target }}
        if action_name == "{{ rule.action }}" and str(target_entity) == "{{ rule.target }}":
            {%- for outcome in rule.outcomes %}
            {%- if outcome.type == "disappear" %}
            self.world.add(agent._facing_location, EmptyEntity())
            {%- elif outcome.type == "change_type" %}
            new_entity = {{ outcome.new_type }}() if "{{ outcome.new_type }}" != "EmptyEntity" else EmptyEntity()
            self.world.add(agent._facing_location, new_entity)
            {%- elif outcome.type == "reward" %}
            agent._pending_reward += {{ outcome.value }}
            {%- endif %}
            {%- endfor %}
        {%- endfor %}
        # --- End of Interaction Rules ---
        {% else %}
        # No interaction rules have been configured.
        pass
        {% endif %}

    def populate_environment(self):
        # ── Fixed layout from grid editor ──────────────────────────────────────
        layout = {{ layout_data }}

        manual_agent_locations = []

        for (r, c), entity_name in layout:
            if entity_name == "Wall":
                self.world.add((r, c, 0), Wall())
            elif entity_name == "Agent":
                manual_agent_locations.append((r, c))
            {% for entity in entities %}
            elif entity_name == "{{ entity.name }}":
                self.world.add((r, c, 0), {{ entity.name }}({{ entity_init_args.get(entity.name, "") }}))
            {% endfor %}

        # ── Random starting locations ──────────────────────────────────────────
        {% if random_starts %}
        # Collect all empty positions (layer 0)
        empty_locs = [
            (r, c)
            for r in range(self.world.height)
            for c in range(self.world.width)
            if isinstance(self.world.observe((r, c, 0)), EmptyEntity)
        ]
        np.random.shuffle(empty_locs)

        {% for rs in random_starts %}
        # Randomly place {{ rs.count }} × {{ rs.entity }}
        for _ in range({{ rs.count }}):
            if empty_locs:
                loc = empty_locs.pop()
                self.world.add((*loc, 0), {{ rs.entity }}({{ entity_init_args.get(rs.entity, "") }}))
        {% endfor %}
        {% endif %}

        # ── Place agents ───────────────────────────────────────────────────────
        # Refresh empty list for agent placement (layer 1)
        agent_empty_locs = [
            (r, c)
            for r in range(self.world.height)
            for c in range(self.world.width)
            if isinstance(self.world.observe((r, c, 0)), EmptyEntity)
               and (r, c) not in manual_agent_locations
        ]
        np.random.shuffle(agent_empty_locs)

        for i, agent in enumerate(self.agents):
            if i < len(manual_agent_locations):
                loc = manual_agent_locations[i]
                self.world.add((*loc, 1), agent)
            elif agent_empty_locs:
                loc = agent_empty_locs.pop()
                self.world.add((*loc, 1), agent)
