import numpy as np
from typing import Optional
from sorrel.agents import Agent
from sorrel.action.action_spec import ActionSpec
from sorrel.observation.observation_spec import ObservationSpec
from sorrel.models.base_model import BaseModel
from sorrel.agents.agent import MovingAgent
from sorrel.examples.{{ project_name_lower }}.world import {{ project_name }}World

class {{ project_name }}Agent({{ base_class }}):
    # Location of the entity this agent is currently "facing" (used for interaction rules).
    _facing_location: Optional[tuple[int, ...]]
    # Reward accumulated from interaction rules this turn (flushed in act()).
    _pending_reward: float

    def __init__(
        self,
        observation_spec: ObservationSpec,
        action_spec: ActionSpec,
        model: BaseModel,
    ):
        super().__init__(observation_spec, action_spec, model)
        self._facing_location = None
        self._pending_reward = 0.0

    def get_action(self, state: np.ndarray) -> int:
        prev_states = self.model.memory.current_state()
        if state is not None:
            stacked_states = np.vstack((prev_states, state))
            model_input = stacked_states.reshape(1, -1)
        else:
            model_input = state
        # Get model output
        model_output = self.model.take_action(model_input)

        return model_output

    def act(self, world: {{project_name}}World, action: int) -> float:

        # Translate the model output to an action string
        action_name = self.action_spec.get_readable_action(action)

        # Attempt to move and track the cell this agent is "facing"
        new_location = self.location  # By default, stay put
        if action_name in ["up", "right", "down", "left"]:
            new_location = self.movement(action)

        # Record which cell was targeted (used by _handle_interaction)
        self._facing_location = new_location

        # Collect the base reward from the entity at the target location
        target_object = world.observe(new_location)
        reward: float = target_object.value

        # Try moving (no-op if the cell is impassable)
        world.move(self, new_location)

        # Flush any reward accumulated by _handle_interaction this turn
        reward += self._pending_reward
        self._pending_reward = 0.0

        return reward